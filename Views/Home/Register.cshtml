@{
    ViewData["Title"] = "Create New Account";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create New Account</title>
    <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                font-family: 'Segoe UI', sans-serif;
            }

            body {
                background-color: #ffffff;
                background-image: radial-gradient(#cccccc 1px, transparent 1px);
                background-size: 20px 20px;
                display: flex;
                justify-content: center;
                align-items: center;
                min-height: 100vh;
                padding: 20px;
            }

            .register-card {
                background: #ffffff;
                width: 100%;
                max-width: 650px; /* Mas malapad para magkasya ang dalawang kahon sa linya */
                padding: 40px;
                border-radius: 8px;
                box-shadow: 0 2px 12px rgba(0,0,0,0.1);
                border: 1px solid #eee;
            }

            h2 {
                text-align: center;
                color: #990000;
                font-size: 26px;
                margin-bottom: 10px;
            }

            .subtitle {
                text-align: center;
                color: #777;
                font-size: 15px;
                margin-bottom: 30px;
            }

            .form-row {
                display: flex;
                gap: 20px;
                margin-bottom: 22px;
                flex-wrap: wrap;
            }

            .form-group {
                flex: 1;
                min-width: 260px;
            }

                .form-group.full {
                    flex: 1 1 100%;
                }

            label {
                display: block;
                margin-bottom: 6px;
                font-size: 15px;
                font-weight: 500;
                color: #333;
            }

            input {
                width: 100%;
                padding: 12px 15px;
                border: 1px solid #990000; /* Gaya ng kulay sa halimbawa mo */
                border-radius: 4px;
                font-size: 15px;
                background-color: #fff;
            }

                input:focus {
                    outline: none;
                    border-color: #660000;
                    box-shadow: 0 0 0 2px rgba(153, 0, 0, 0.15);
                }

            .btn-create {
                width: 100%;
                background-color: #990000;
                color: white;
                border: none;
                padding: 13px;
                font-size: 17px;
                font-weight: 600;
                border-radius: 4px;
                cursor: pointer;
                margin: 15px 0 12px;
            }

                .btn-create:hover {
                    background-color: #800000;
                }

            .btn-back {
                width: 100%;
                background-color: #e9ecef;
                color: #333;
                border: none;
                padding: 13px;
                font-size: 17px;
                font-weight: 500;
                border-radius: 4px;
                cursor: pointer;
                display: block;
                text-align: center;
                text-decoration: none;
            }

            .link-bottom {
                text-align: center;
                margin-top: 20px;
                font-size: 15px;
            }

                .link-bottom a {
                    color: #990000;
                    text-decoration: none;
                    font-weight: 600;
                }

            .msg-success {
                background: #d4edda;
                border: 1px solid #c3e6cb;
                color: #155724;
                padding: 10px;
                margin-bottom: 20px;
                border-radius: 4px;
                text-align: center;
            }

            .msg-error {
                background: #f8d7da;
                border: 1px solid #f5c6cb;
                color: #721c24;
                padding: 10px;
                margin-bottom: 20px;
                border-radius: 4px;
                text-align: center;
            }
    </style>
</head>
<body>
    <div class="register-card">
        <h2>CREATE NEW ACCOUNT</h2>
        <p class="subtitle">Fill in all required details</p>

        @if (!string.IsNullOrEmpty(ViewBag.Success))
        {
            <div class="msg-success">@ViewBag.Success</div>
        }
        @if (!string.IsNullOrEmpty(ViewBag.Error))
        {
            <div class="msg-error">@ViewBag.Error</div>
        }

        <!-- ✅ Isang linya = dalawang kahon, gaya ng gusto mo -->
        <form asp-action="Register" method="post">
            <div class="form-row">
                <div class="form-group full">
                    <label>ACCOUNT</label>
                    <input type="text" name="ACCOUNT" placeholder="Enter value" required />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>ADDRESS</label>
                    <input type="text" name="ADDRESS" placeholder="Enter value" />
                </div>
                <div class="form-group">
                    <label>CONTACT</label>
                    <input type="text" name="CONTACT" placeholder="Enter value" required />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>EMAIL</label>
                    <input type="email" name="EMAIL" placeholder="Enter value" required />
                </div>
                <div class="form-group">
                    <label>USERNAME</label>
                    <input type="text" name="USERNAME" placeholder="Enter value" required />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group full">
                    <label>PASSWORD</label>
                    <input type="password" name="PASSWORD" placeholder="Enter value" required />
                </div>
            </div>

            <button type="submit" class="btn-create">✅ Create Account</button>
            <a asp-action="Index" class="btn-back">⬅️ Back to Login</a>
        </form>

        <div class="link-bottom">
            Already have an account? <a asp-action="Index">Sign in here</a>
        </div>
    </div>
</body>
</html>