@{
    ViewData["Title"] = "Dashboard";
    int branchCount = ViewBag.BranchCount ?? 0;
    int userCount = ViewBag.UserCount ?? 0;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CodeNect System Alliance</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                font-family: 'Segoe UI', sans-serif;
            }

            body {
                background-color: #f8fafc;
                color: #1e293b;
            }

            .app-container {
                display: flex;
                min-height: 100vh;
            }

            /* SIDEBAR - Simpleng Menu Lang */
            .sidebar {
                width: 200px;
                background: #ffffff;
                border-right: 1px solid #e5e7eb;
                padding: 20px 0;
            }

                .sidebar .logo {
                    font-size: 18px;
                    font-weight: bold;
                    color: #990000;
                    padding: 0 16px 25px;
                    display: block;
                }

            .sidebar-menu a {
                display: block;
                padding: 10px 16px;
                margin: 4px 0;
                color: #333;
                text-decoration: none;
                font-size: 14px;
            }

                .sidebar-menu a:hover,
                .sidebar-menu a.active {
                    background: #990000;
                    color: #ffffff;
                }

            /* MAIN CONTENT */
            .main-content {
                flex: 1;
                padding: 30px;
            }

            .dashboard-header h2 {
                font-size: 26px;
                font-weight: 600;
                margin-bottom: 8px;
            }

            .dashboard-header p {
                color: #6b7280;
                margin-bottom: 30px;
            }

            .stats-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
                gap: 20px;
                max-width: 750px;
            }

            .stat-card {
                background: #ffffff;
                padding: 24px;
                border: 1px solid #e5e7eb;
                border-radius: 4px;
            }

                .stat-card .number {
                    font-size: 28px;
                    font-weight: 700;
                    color: #990000;
                    margin-bottom: 8px;
                }

                .stat-card .label {
                    font-size: 15px;
                    color: #4b5563;
                }
    </style>
</head>
<body>
    <div class="app-container">

        <!-- ✅ MENU: Dashboard, Users, Branches Lang -->
        <aside class="sidebar">
            <div class="logo">Inventory</div>
            <div class="sidebar-menu">
                <a href="@Url.Action("Dashboard")" class="active">📊 Dashboard</a>
                <a href="@Url.Action("UserAccount")">👤 Users</a>
                <a href="@Url.Action("Branches")">🏢 Branches</a>
                <li><a href="#">📦 Inventory</a></li>
                <li><a href="#">⚙️ Settings</a></li>
                <li><a href="#">🔒 Security</a></li>
            </div>
        </aside>

        <div class="main-content">
            <div class="dashboard-header">
                <h2>Welcome to CodeNect System Alliance</h2>
                <p>Manage your inventory, branches, and users from here.</p>
            </div>

            <div class="stats-grid">
                <!-- Bilang ng Branches -->
                <div class="stat-card">
                    <div class="number">@branchCount</div>
                    <div class="label">Active Branches</div>
                </div>

                <!-- Bilang ng Users -->
                <div class="stat-card">
                    <div class="number">@userCount</div>
                    <div class="label">Registered Users</div>
                </div>

                <!-- Fixed Info -->
                <div class="stat-card">
                    <div class="number">24/7</div>
                    <div class="label">System Access</div>
                </div>
            </div>
        </div>

    </div>
</body>
</html>