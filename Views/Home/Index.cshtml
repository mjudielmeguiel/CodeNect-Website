@{
    ViewData["Title"] = "Home";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CodeNect System Alliance</title>
    <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                font-family: 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            }

            :root {
                --primary: #990000;
                --primary-hover: #800000;
                --light-gray: #f8f9fa;
                --border-gray: #e5e7eb;
                --text-gray: #6b7280;
                --text-dark: #111827;
                --white: #ffffff;
            }

            body {
                background-color: #ffffff;
                background-image: radial-gradient(#e0e0e0 1px, transparent 0);
                background-size: 24px 24px;
                background-position: 12px 12px;
                color: var(--text-dark);
                line-height: 1.6;
            }

            .container {
                max-width: 1140px;
                margin: 0 auto;
                padding: 0 24px;
            }

            /* Header */
            header {
                padding: 20px 0;
                border-bottom: 1px solid #f0f0f0;
                background-color: rgba(255,255,255,0.95);
                position: sticky;
                top: 0;
                z-index: 99;
            }

            .header-content {
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            .logo {
                font-size: 18px;
                font-weight: 700;
                color: var(--text-dark);
                display: flex;
                align-items: center;
                gap: 8px;
            }

                .logo span:first-child {
                    color: var(--primary);
                    font-size: 22px;
                }

            .nav-links {
                display: flex;
                align-items: center;
                gap: 28px;
                font-size: 14px;
            }

                .nav-links a {
                    text-decoration: none;
                    color: var(--text-dark);
                    font-weight: 500;
                    transition: color 0.2s;
                }

                    .nav-links a:hover {
                        color: var(--primary);
                    }

            /* Hero Section */
            .hero-section {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 60px 0;
                gap: 40px;
                min-height: 85vh;
            }

            .hero-left {
                flex: 1;
            }

            .badge {
                display: inline-block;
                font-size: 12px;
                color: var(--primary);
                background-color: #fff0f0;
                padding: 5px 14px;
                border-radius: 20px;
                margin-bottom: 20px;
                font-weight: 500;
            }

            .hero-left h1 {
                font-size: 52px;
                font-weight: 800;
                line-height: 1.1;
                margin-bottom: 20px;
            }

                .hero-left h1 span {
                    color: var(--primary);
                }

            .hero-left p {
                font-size: 17px;
                color: var(--text-gray);
                margin-bottom: 30px;
                max-width: 480px;
                line-height: 1.7;
            }

            .btn-download {
                display: inline-block;
                background-color: var(--primary);
                color: var(--white);
                border: none;
                padding: 12px 28px;
                font-size: 15px;
                font-weight: 600;
                border-radius: 6px;
                text-decoration: none;
                margin-bottom: 35px;
                transition: background-color 0.2s ease;
                cursor: pointer;
            }

                .btn-download:hover {
                    background-color: var(--primary-hover);
                }

            .stats-row {
                display: flex;
                gap: 40px;
            }

            .stat-item {
                text-align: left;
            }

            .stat-value {
                font-size: 32px;
                font-weight: 700;
                color: var(--primary);
                display: block;
                line-height: 1;
            }

            .stat-label {
                font-size: 13px;
                text-transform: uppercase;
                color: var(--text-gray);
                letter-spacing: 0.8px;
                margin-top: 4px;
            }

            /* Login Card */
            .login-card {
                width: 360px;
                background: var(--white);
                border-radius: 12px;
                box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08), 0 2px 10px rgba(0, 0, 0, 0.03);
                padding: 32px 28px;
                border: none;
            }

                .login-card h3 {
                    text-align: center;
                    font-size: 18px;
                    font-weight: 700;
                    color: var(--text-dark);
                    margin-bottom: 6px;
                }

            .login-tagline {
                text-align: center;
                font-size: 13px;
                color: var(--text-gray);
                font-style: normal;
                margin-bottom: 28px;
            }

            .form-group {
                margin-bottom: 20px;
            }

                .form-group label {
                    display: block;
                    font-size: 14px;
                    font-weight: 500;
                    margin-bottom: 8px;
                    color: var(--text-dark);
                }

                .form-group input {
                    width: 100%;
                    padding: 12px 16px;
                    border: 1.5px solid var(--border-gray);
                    border-radius: 8px;
                    font-size: 15px;
                    background-color: #fcfcfc;
                    transition: all 0.2s ease;
                }

                    .form-group input:focus {
                        outline: none;
                        border-color: var(--primary);
                        background-color: var(--white);
                        box-shadow: 0 0 0 3px rgba(153, 0, 0, 0.1);
                    }

            .password-wrapper {
                position: relative;
            }

            .toggle-pass {
                position: absolute;
                right: 14px;
                top: 13px;
                cursor: pointer;
                color: var(--text-gray);
                font-size: 16px;
            }

            .btn-login {
                width: 100%;
                background-color: var(--primary);
                color: var(--white);
                border: none;
                padding: 13px;
                font-size: 16px;
                font-weight: 600;
                border-radius: 8px;
                cursor: pointer;
                transition: background-color 0.2s ease;
                margin-top: 8px;
            }

                .btn-login:hover {
                    background-color: var(--primary-hover);
                }

            .login-links {
                text-align: center;
                margin-top: 22px;
                font-size: 13px;
            }

                .login-links a {
                    color: var(--primary);
                    text-decoration: none;
                    font-weight: 500;
                    transition: color 0.2s;
                }

                    .login-links a:hover {
                        color: var(--primary-hover);
                        text-decoration: underline;
                    }

            .error-msg {
                margin-top: 16px;
                padding: 10px;
                background-color: #fff2f2;
                border: 1px solid #ffd6d6;
                color: #b30000;
                font-size: 13px;
                text-align: center;
                border-radius: 6px;
            }

            /* ✅ BAGONG SEKSYON: LAYUNIN NG SYSTEM */
            .purpose-section {
                padding: 70px 0;
                background-color: rgba(255,255,255,0.6);
            }

            .section-heading {
                text-align: center;
                margin-bottom: 50px;
            }

                .section-heading h2 {
                    font-size: 32px;
                    font-weight: 700;
                    color: var(--text-dark);
                    margin-bottom: 12px;
                }

                .section-heading p {
                    font-size: 16px;
                    color: var(--text-gray);
                    max-width: 700px;
                    margin: 0 auto;
                }

            .purpose-grid {
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 30px;
                align-items: center;
            }

            .purpose-text h3 {
                font-size: 22px;
                color: var(--primary);
                margin-bottom: 15px;
            }

            .purpose-text p {
                font-size: 15px;
                color: var(--text-gray);
                line-height: 1.8;
                margin-bottom: 12px;
            }

            .purpose-list {
                list-style: none;
            }

                .purpose-list li {
                    padding: 8px 0;
                    color: var(--text-dark);
                    font-weight: 500;
                }

                    .purpose-list li::before {
                        content: "✓";
                        color: var(--primary);
                        font-weight: bold;
                        margin-right: 10px;
                    }

            /* ✅ BAGONG SEKSYON: BAKIT ITO ANG KAILANGAN MO */
            .why-section {
                padding: 70px 0;
            }

            .why-grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 28px;
            }

            .why-card {
                background-color: var(--white);
                padding: 30px 24px;
                border-radius: 12px;
                box-shadow: 0 4px 15px rgba(0,0,0,0.05);
                text-align: center;
                transition: transform 0.3s ease;
            }

                .why-card:hover {
                    transform: translateY(-5px);
                }

            .why-icon {
                font-size: 40px;
                margin-bottom: 15px;
            }

            .why-card h4 {
                font-size: 18px;
                color: var(--primary);
                margin-bottom: 10px;
            }

            .why-card p {
                font-size: 14px;
                color: var(--text-gray);
                line-height: 1.7;
            }

            /* Modules Section */
            .modules-section {
                background-color: var(--light-gray);
                padding: 60px 0 80px;
            }

            .modules-header {
                text-align: center;
                margin-bottom: 40px;
            }

                .modules-header h2 {
                    font-size: 28px;
                    font-weight: 700;
                    margin-bottom: 8px;
                }

                .modules-header p {
                    font-size: 15px;
                    color: var(--text-gray);
                }

            .modules-grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 24px;
            }

            .module-card {
                background-color: var(--white);
                border-radius: 10px;
                overflow: hidden;
                box-shadow: 0 2px 8px rgba(0,0,0,0.06);
                transition: transform 0.2s ease;
            }

                .module-card:hover {
                    transform: translateY(-2px);
                }

            .module-header {
                background-color: var(--primary);
                color: var(--white);
                padding: 12px 16px;
                font-size: 15px;
                font-weight: 600;
            }

            .module-body {
                padding: 16px;
                font-size: 14px;
                color: var(--text-gray);
                line-height: 1.7;
            }

            /* ✅ BAGONG SEKSYON: TUNGKOL SA AMIN */
            .about-section {
                padding: 70px 0;
                background-color: rgba(255,255,255,0.6);
            }

            .about-text {
                max-width: 800px;
                margin: 0 auto;
                text-align: center;
                font-size: 15px;
                color: var(--text-gray);
                line-height: 1.8;
            }

            /* Footer */
            footer {
                background-color: var(--text-dark);
                color: #ccc;
                padding: 40px 0 20px;
                text-align: center;
                font-size: 13px;
            }

                footer p {
                    margin-bottom: 8px;
                }

            /* Responsive */
            @@media only screen and (max-width: 992px) {
                .modules-grid, .why-grid {
                    grid-template-columns: repeat(2, 1fr);
                }

                .purpose-grid {
                    grid-template-columns: 1fr;
                }

                .hero-section {
                    flex-direction: column;
                    text-align: center;
                }

                .hero-left p {
                    margin-left: auto;
                    margin-right: auto;
                }

                .stats-row {
                    justify-content: center;
                }
            }
            @@media only screen and (max-width: 576px) {
                .modules-grid, .why-grid {
                    grid-template-columns: 1fr;
                }

                .hero-left h1 {
                    font-size: 36px;
                }

                .login-card {
                    width: 100%;
                }
            }
    </style>
</head>
<body>

    <!-- Header -->
    <header>
        <div class="container header-content">
            <div class="logo">
                <span>C</span> CodeNect System Alliance
            </div>
            <nav class="nav-links">
                <a href="#purpose">Purpose</a>
                <a href="#features">Why Us</a>
                <a href="#modules">Modules</a>
                <a asp-action="PricingPlans">Pricing</a>
                <a href="#">Support</a>
            </nav>
        </div>
    </header>

    <!-- Hero & Login Section -->
    <div class="container hero-section">
        <div class="hero-left">
            <div class="badge">Official Business & Inventory Platform</div>
            <h1>All Operations.<br><span>One System.</span></h1>
            <p>
                CodeNect System Alliance — complete tools for inventory, stock management, ordering, transfers, and reporting. Built for speed, accuracy, and control.
            </p>
            <a asp-action="PricingPlans" class="btn-download">View Pricing & Download</a>
            <div class="stats-row">
                <div class="stat-item">
                    <span class="stat-value">@ViewData["TotalAccounts"]+</span>
                    <span class="stat-label">DOWNLOADS</span>
                </div>
                <div class="stat-item">
                    <span class="stat-value">10</span>
                    <span class="stat-label">ACTIVE USERS</span>
                </div>
                <div class="stat-item">
                    <span class="stat-value">24/7</span>
                    <span class="stat-label">ACCESS</span>
                </div>
            </div>
        </div>

        <!-- Login Box -->
        <div id="login" class="login-card">
            <h3>CODENECT SYSTEM ALLIANCE</h3>
            <p class="login-tagline">"Experience Better for Improving Services"</p>
            <form asp-action="Login" method="post">
                <div class="form-group">
                    <label>Username</label>
                    <input type="text" name="Username" placeholder="Enter your username" required />
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <div class="password-wrapper">
                        <input type="password" name="Password" id="passwordField" placeholder="Enter your password" required />
                        <span class="toggle-pass" onclick="togglePass()">👁</span>
                    </div>
                </div>
                <button type="submit" class="btn-login">Login</button>
            </form>
            <div class="login-links">
                <a href="#">Forgot Password?</a>
            </div>
            @if (!string.IsNullOrEmpty(ViewBag.Error))
            {
                <div class="error-msg">@ViewBag.Error</div>
            }
        </div>
    </div>

    <!-- ✅ SEKSYON: LAYUNIN NG SYSTEM -->
    <section id="purpose" class="purpose-section">
        <div class="container">
            <div class="section-heading">
                <h2>Purpose of the System</h2>
                <p>Why was CodeNect System Alliance built, and what problems does it solve for your business?</p>
            </div>
            <div class="purpose-grid">
                <div class="purpose-text">
                    <h3>Streamline Your Business Operations</h3>
                    <p>The main goal of this system is to replace manual recording, logbooks, and scattered spreadsheets with one unified platform. It ensures that every product, transaction, and report is recorded accurately and instantly.</p>
                    <p>It is designed for small to medium businesses, branches, and suppliers who want to have full control over their inventory without the confusion and errors of manual work.</p>
                </div>
                <div>
                    <ul class="purpose-list">
                        <li>Eliminate inventory errors and missing items</li>
                        <li>Track stock levels automatically in real-time</li>
                        <li>Monitor sales, orders, and transfers across branches</li>
                        <li>Generate accurate reports for decision making</li>
                        <li>Secure your data and access it anywhere</li>
                        <li>Save time and reduce workload for your staff</li>
                        <li>Prevent stock shortages and overstocking</li>
                        <li>Centralize all data in one safe database</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- ✅ SEKSYON: BAKIT ITO ANG KAILANGAN MO -->
    <section id="features" class="why-section">
        <div class="container">
            <div class="section-heading">
                <h2>Why Choose CodeNect System Alliance?</h2>
                <p>Simple, reliable, and built exactly for how your business works.</p>
            </div>
            <div class="why-grid">
                <div class="why-card">
                    <div class="why-icon">⚡</div>
                    <h4>Fast & Easy to Use</h4>
                    <p>Designed to be familiar and simple. No complicated setup — your team can learn and use it right away.</p>
                </div>
                <div class="why-card">
                    <div class="why-icon">🔒</div>
                    <h4>Secure & Organized</h4>
                    <p>User accounts, roles, and permissions ensure only authorized people can access sensitive data.</p>
                </div>
                <div class="why-card">
                    <div class="why-icon">📊</div>
                    <h4>Real-Time Reports</h4>
                    <p>See your sales, available stock, and history instantly. Helps you make the right decisions for your business.</p>
                </div>
                <div class="why-card">
                    <div class="why-icon">🌐</div>
                    <h4>Online & Accessible</h4>
                    <p>Connect anywhere with internet. Works across branches and keeps all data updated at the same time.</p>
                </div>
                <div class="why-card">
                    <div class="why-icon">🔄</div>
                    <h4>Complete Integration</h4>
                    <p>From ordering to selling and transferring — everything is connected and recorded automatically.</p>
                </div>
                <div class="why-card">
                    <div class="why-icon">💸</div>
                    <h4>Affordable Plans</h4>
                    <p>Choose the right package for your business size — from free basic use to full enterprise features.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Modules Section -->
    <section id="modules" class="modules-section">
        <div class="container">
            <div class="modules-header">
                <h2>Available System Modules</h2>
                <p>All the tools you use daily in one unified platform.</p>
            </div>
            <div class="modules-grid">
                <div class="module-card">
                    <div class="module-header">IT SUPPORT DASHBOARD</div>
                    <div class="module-body">
                        <strong>File • Monitoring • Settings • Reports • Products • Branches • Vendors • Sales</strong><br>
                        Main control panel — view inventory, transactions, user info, and system status in real-time.
                    </div>
                </div>
                <div class="module-card">
                    <div class="module-header">STOCK ORDER</div>
                    <div class="module-body">
                        <strong>Create orders from suppliers, assign to branches, track status</strong><br>
                        Input barcode, quantity, vendor details, and submit purchase requests easily.
                    </div>
                </div>
                <div class="module-card">
                    <div class="module-header">STOCK TRANSFER</div>
                    <div class="module-body">
                        <strong>Move items between branches, record quantities, update inventory</strong><br>
                        Transfer stock from one location to another with full audit trail.
                    </div>
                </div>
                <div class="module-card">
                    <div class="module-header">RETURN TO VENDOR</div>
                    <div class="module-body">
                        <strong>Process returns, update stock out, track credit notes</strong><br>
                        Log damaged, expired, or wrong items sent back to suppliers.
                    </div>
                </div>
                <div class="module-card">
                    <div class="module-header">INVENTORY MANAGEMENT</div>
                    <div class="module-body">
                        <strong>Add, update, remove items, export data, view stock levels</strong><br>
                        Complete control of your stock — prices, sizes, brands, and availability.
                    </div>
                </div>
                <div class="module-card">
                    <div class="module-header">PRICE ADJUSTMENT</div>
                    <div class="module-body">
                        <strong>Update costs, selling prices, and vendor info instantly</strong><br>
                        Change pricing details and product information without leaving the system.
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ✅ SEKSYON: TUNGKOL SA AMIN -->
    <section class="about-section">
        <div class="container">
            <div class="section-heading">
                <h2>About CodeNect System Alliance</h2>
            </div>
            <div class="about-text">
                <p>CodeNect System Alliance was created to provide reliable and easy-to-use inventory and business management solutions for Filipino businesses. We understand that managing stocks and transactions can be time-consuming and difficult without the right tools.</p>
                <p>Our goal is to help business owners and staff focus more on growing their business, while the system takes care of organizing, recording, and securing your data accurately. Every part of this system is built with attention to detail, security, and practical use in mind.</p>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <div class="container">
            <p>&copy; 2026 CodeNect System Alliance. All Rights Reserved.</p>
            <p>"Experience Better for Improving Services"</p>
        </div>
    </footer>

    <script>
            function togglePass() {
                const el = document.getElementById('passwordField');
                el.type = el.type === 'password' ? 'text' : 'password';
            }
    </script>

</body>
</html>