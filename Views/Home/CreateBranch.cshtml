@{
    ViewData["Title"] = "Create New Branch";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create New Branch</title>
    <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                font-family: 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            }

            body {
                background-color: #ffffff;
                background-image: radial-gradient(#cccccc 1px, transparent 1px);
                background-size: 20px 20px;
                display: flex;
                justify-content: center;
                align-items: center;
                min-height: 100vh;
                padding: 20px;
            }

            .form-card {
                background: #ffffff;
                width: 100%;
                max-width: 680px;
                padding: 35px;
                border-radius: 8px;
                box-shadow: 0 2px 12px rgba(0,0,0,0.1);
                border: 1px solid #eee;
            }

            .form-header {
                text-align: center;
                margin-bottom: 30px;
            }

                .form-header h2 {
                    font-size: 26px;
                    font-weight: 700;
                    color: #990000;
                    margin-bottom: 8px;
                }

                .form-header p {
                    font-size: 15px;
                    color: #666666;
                }

            .msg-success {
                background: #dcfce7;
                border: 1px solid #bbf7d0;
                color: #166534;
                padding: 10px;
                margin-bottom: 20px;
                border-radius: 4px;
                text-align: center;
                font-weight: 500;
            }

            .msg-error {
                background: #fee2e2;
                border: 1px solid #fecaca;
                color: #991b1b;
                padding: 10px;
                margin-bottom: 20px;
                border-radius: 4px;
                text-align: center;
                font-weight: 500;
            }

            .form-row {
                display: flex;
                gap: 25px;
                margin-bottom: 22px;
                flex-wrap: wrap;
            }

            .form-group {
                flex: 1;
                min-width: 260px;
            }

                .form-group.full {
                    flex: 1 1 100%;
                }

            label {
                display: block;
                margin-bottom: 8px;
                font-size: 15px;
                font-weight: 500;
                color: #333333;
            }

                label span {
                    color: #990000;
                }

            input, select {
                width: 100%;
                padding: 12px 15px;
                border: 1px solid #990000;
                border-radius: 4px;
                font-size: 15px;
                background-color: #ffffff;
            }

                input:focus, select:focus {
                    outline: none;
                    border-color: #660000;
                    box-shadow: 0 0 0 2px rgba(153, 0, 0, 0.15);
                }

            .btn-submit {
                width: 100%;
                background-color: #990000;
                color: white;
                border: none;
                padding: 14px;
                border-radius: 4px;
                font-size: 17px;
                font-weight: 600;
                cursor: pointer;
                margin: 15px 0 12px;
                transition: background 0.2s;
            }

                .btn-submit:hover {
                    background-color: #800000;
                }

            .btn-back {
                display: block;
                width: 100%;
                background-color: #e9ecef;
                color: #333333;
                border: none;
                padding: 14px;
                border-radius: 4px;
                font-size: 16px;
                font-weight: 500;
                text-align: center;
                text-decoration: none;
                margin-bottom: 0;
            }

                .btn-back:hover {
                    background-color: #dee2e6;
                }
    </style>
</head>
<body>
    <div class="form-card">
        <div class="form-header">
            <h2>CREATE NEW BRANCH</h2>
            <p>Fill in all required details</p>
        </div>

        @if (!string.IsNullOrEmpty(ViewBag.Success))
        {
            <div class="msg-success">@ViewBag.Success</div>
        }
        @if (!string.IsNullOrEmpty(ViewBag.Error))
        {
            <div class="msg-error">@ViewBag.Error</div>
        }

        <form asp-action="CreateBranch" method="post">
            <div class="form-row">
                <div class="form-group full">
                    <label>BRANCH <span>*</span></label>
                    <input type="text" name="BRANCH" placeholder="Enter value" required />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group full">
                    <label>BUSINESS TYPE <span>*</span></label>
                    <select name="BUSINESS_TYPE" required>
                        <option value="">Select Business Type</option>
                        <option value="RETAIL STORE">RETAIL STORE</option>
                        <option value="WHOLESALE OUTLET">WHOLESALE OUTLET</option>
                        <option value="FOOD OUTLET">FOOD OUTLET</option>
                        <option value="SERVICE CENTER">SERVICE CENTER</option>
                        <option value="WAREHOUSE">WAREHOUSE</option>
                        <option value="OFFICE ONLY">OFFICE ONLY</option>
                    </select>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>CONTACT <span>*</span></label>
                    <input type="text" name="CONTACT" placeholder="Enter value" required />
                </div>
                <div class="form-group">
                    <label>EMAIL</label>
                    <input type="email" name="EMAIL" placeholder="Enter value" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>MANAGER</label>
                    <input type="text" name="MANAGER" placeholder="Enter value" />
                </div>
                <div class="form-group">
                    <label>TIN</label>
                    <input type="text" name="TIN" placeholder="Enter value" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group full">
                    <label>STATUS <span>*</span></label>
                    <select name="STATUS" required>
                        <option value="">Select Status</option>
                        <option value="Active">Active</option>
                        <option value="Inactive">Inactive</option>
                    </select>
                </div>
            </div>

            <button type="submit" class="btn-submit">✅ Create Branch</button>
        </form>

        <a asp-action="Dashboard" class="btn-back">← Back to Dashboard</a>
    </div>
</body>
</html>