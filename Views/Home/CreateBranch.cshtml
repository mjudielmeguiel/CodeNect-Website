@{
    ViewData["Title"] = "Create New Branch";
    var managers = ViewBag.Managers as List<string> ?? new List<string>();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create New Branch</title>
    <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                font-family: 'Segoe UI', sans-serif;
            }

            body {
                background-color: #ffffff;
                padding: 30px;
            }

            .form-container {
                max-width: 620px;
                margin: 0 auto;
                background: #ffffff;
                padding: 35px 40px;
                border-radius: 8px;
                box-shadow: 0 1px 6px rgba(0, 0, 0, 0.12);
                border: 1px solid #e8e8e8;
            }

            .form-title {
                text-align: center;
                color: #990000;
                font-size: 22px;
                font-weight: 700;
                margin-bottom: 30px;
                letter-spacing: 0.3px;
            }

            .error-box {
                background: #fdeaea;
                color: #990000;
                padding: 10px 12px;
                border-radius: 4px;
                margin-bottom: 20px;
                border: 1px solid #f8cccc;
                font-size: 14px;
            }

            .form-grid {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 20px 22px;
                margin-bottom: 28px;
            }

            .form-group.full {
                grid-column: 1 / -1;
            }

            label {
                display: block;
                margin-bottom: 6px;
                font-weight: 500;
                color: #222222;
                font-size: 14.5px;
            }

            input, select {
                width: 100%;
                padding: 8px 10px;
                border: 1px solid #990000;
                border-radius: 3px;
                font-size: 14.5px;
                background-color: #ffffff;
            }

                input:focus, select:focus {
                    outline: none;
                    border-color: #7a0000;
                    box-shadow: 0 0 0 1.5px rgba(153, 0, 0, 0.15);
                }

            .btn-submit {
                width: 100%;
                background-color: #990000;
                color: #ffffff;
                padding: 10px;
                border: none;
                border-radius: 3px;
                font-size: 15.5px;
                font-weight: 600;
                cursor: pointer;
            }

                .btn-submit:hover {
                    background-color: #800000;
                }

            .back-link {
                text-align: center;
                margin-top: 20px;
            }

                .back-link a {
                    color: #990000;
                    text-decoration: none;
                    font-size: 14.5px;
                    font-weight: 500;
                }

                    .back-link a:hover {
                        text-decoration: underline;
                    }
    </style>
</head>
<body>
    <div class="form-container">
        <h2 class="form-title">CREATE NEW BRANCH</h2>

        @if (!string.IsNullOrEmpty(ViewBag.Error))
        {
            <div class="error-box">@ViewBag.Error</div>
        }

        <form asp-action="CreateBranchSubmit" method="post">
            <div class="form-grid">
                <!-- Branch Name - Full Width -->
                <div class="form-group full">
                    <label>Branch Name</label>
                    <input type="text" name="BRANCH" />
                </div>

                <!-- Business Type - Full Width -->
                <div class="form-group full">
                    <label>Business Type *</label>
                    <select name="BUSINESS_TYPE" required>
                        <option value="">-- Select Type --</option>
                        <option value="RETAIL STORE">RETAIL STORE</option>
                        <option value="WHOLESALE OUTLET">WHOLESALE OUTLET</option>
                        <option value="FOOD OUTLET">FOOD OUTLET</option>
                        <option value="SERVICE CENTER">SERVICE CENTER</option>
                        <option value="WAREHOUSE">WAREHOUSE</option>
                        <option value="OFFICE ONLY">OFFICE ONLY</option>
                    </select>
                </div>

                <!-- TIN and TIN Registered - Side by Side -->
                <div class="form-group">
                    <label>TIN</label>
                    <input type="text" name="TIN" />
                </div>

                <div class="form-group">
                    <label>TIN Registered</label>
                    <input type="date" name="TIN_REGISTERED" />
                </div>

                <!-- Address - Full Width -->
                <div class="form-group full">
                    <label>Address</label>
                    <input type="text" name="ADDRESS" />
                </div>

                <!-- Email and Contact Number - Side by Side -->
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" name="EMAIL" />
                </div>

                <div class="form-group">
                    <label>Contact Number</label>
                    <input type="text" name="CONTACT" />
                </div>

                <!-- Manager - Full Width -->
                <div class="form-group full">
                    <label>Manager</label>
                    <select name="MANAGER">
                        <option value="">-- Select Manager --</option>
                        @foreach (var manager in managers)
                        {
                            <option value="@manager">@manager</option>
                        }
                    </select>
                </div>
            </div>

            <button type="submit" class="btn-submit">💾 SAVE BRANCH</button>
        </form>

        <div class="back-link">
            <a asp-action="Branches">← Back to Branch List</a>
        </div>
    </div>
</body>
</html>